# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Shortcut - https://app.shortcut.com/settings/account/api-tokens
SHORTCUT_API_TOKEN=...

# Figma - https://www.figma.com/settings → Personal access tokens
FIGMA_API_TOKEN=...

# Figma search scope (at least one is required for Figma search)
# Your team ID from the Figma team URL: figma.com/files/team/{TEAM_ID}
FIGMA_TEAM_ID=
# Optional: narrow to a specific project ID instead
FIGMA_PROJECT_ID=
